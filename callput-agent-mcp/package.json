{
    "name": "callput-agent-server",
    "version": "1.0.0",
    "description": "MCP Server for Callput.app Agentic Economy",
    "type": "module",
    "main": "build/index.js",
    "scripts": {
        "start": "node build/index.js",
        "build": "tsc",
        "dev": "ts-node src/index.ts",
        "start:stdio": "node build/index.js",
        "verify:tools": "npx ts-node verify_refactor_tools.ts",
        "verify:flow": "npx ts-node verify_trade_flow.ts",
        "verify:advanced": "npx ts-node verify_advanced_features.ts",
        "verify:e2e": "npx ts-node e2e_agent_test.ts",
        "verify:input": "npx ts-node verify_input_validation.ts",
        "verify:bootstrap": "npx ts-node verify_bootstrap.ts",
        "verify:settle": "npx ts-node verify_settle.ts",
        "verify:core": "npm run build && node build/test_connection.js && node build/test_s3_fetch.js && npm run verify:tools && npm run verify:flow && npm run verify:advanced && npm run verify:input && npm run verify:bootstrap"
    },
    "keywords": [
        "mcp",
        "agent",
        "callput"
    ],
    "author": "Callput Team",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "dotenv": "^16.6.1",
        "ethers": "^6.16.0",
        "viem": "^2.0.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.0.0"
    }
}
